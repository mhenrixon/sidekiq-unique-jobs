#!/usr/bin/env ruby
# frozen_string_literal: true

# Compare performance between branches:
#   git checkout main && bin/benchmark_improvements > results_v8.txt
#   git checkout v9   && bin/benchmark_improvements > results_v9.txt
#   diff results_v8.txt results_v9.txt

begin
  require "benchmark/ips"
  require "benchmark/memory"
rescue LoadError
  abort "Install: gem install benchmark-ips benchmark-memory --no-document"
end

require "bundler/setup"
require "sidekiq"
require "sidekiq-unique-jobs"
require "concurrent"

Sidekiq.configure_client do |config|
  config.redis = { url: ENV.fetch("REDIS_URL", "redis://localhost:6379/0") }
  config.client_middleware do |chain|
    chain.add SidekiqUniqueJobs::Middleware::Client
  end
end

SidekiqUniqueJobs.configure do |config|
  config.lock_info = false
  config.logger_enabled = false
end

SidekiqUniqueJobs.redis { |conn| conn.call("FLUSHDB") }

puts "=" * 70
puts "SIDEKIQ UNIQUE JOBS - CROSS-BRANCH COMPARISON"
puts "=" * 70
puts "Version: #{SidekiqUniqueJobs::VERSION}"
puts "Ruby: #{RUBY_VERSION} | Sidekiq: #{Sidekiq::VERSION}"
puts "Branch: #{`git rev-parse --abbrev-ref HEAD`.chomp}"
puts "Commit: #{`git rev-parse --short HEAD`.chomp}"
puts "=" * 70

def create_item(lock_type: "until_executed", args: %w[arg1 arg2], lock_ttl: nil)
  {
    "jid" => SecureRandom.hex(12),
    "class" => "BenchmarkJob",
    "queue" => "default",
    "lock" => lock_type,
    "args" => args,
    "lock_args" => args,
    "lock_timeout" => 0,
    "lock_ttl" => lock_ttl,
  }
end

def prepare(item)
  SidekiqUniqueJobs::Job.prepare(item)
  item
end

def random_args
  [SecureRandom.hex(8), { "type" => SecureRandom.hex(4) }]
end

# === 1: Core lock/unlock throughput ===
puts "\n[1] LOCK/UNLOCK THROUGHPUT"
Benchmark.ips do |x|
  x.config(time: 10, warmup: 3)

  x.report("lock + unlock") do
    item = prepare(create_item)
    ls = SidekiqUniqueJobs::Locksmith.new(item)
    ls.lock
    ls.unlock
  end

  x.report("lock + execute { nil }") do
    item = prepare(create_item)
    ls = SidekiqUniqueJobs::Locksmith.new(item)
    ls.execute { nil }
  end
end

# === 2: Lock under contention ===
puts "\n[2] LOCK CONTENTION"
Benchmark.ips do |x|
  x.config(time: 10, warmup: 3)

  x.report("unique args (no contention)") do
    item = prepare(create_item(args: random_args))
    ls = SidekiqUniqueJobs::Locksmith.new(item)
    ls.lock
    ls.unlock
  end

  x.report("same args (contention)") do
    item = prepare(create_item)
    ls1 = SidekiqUniqueJobs::Locksmith.new(item)
    ls1.lock

    item2 = prepare(create_item)
    ls2 = SidekiqUniqueJobs::Locksmith.new(item2)
    ls2.lock

    ls1.unlock
  end
end

# === 3: Concurrent locks ===
puts "\n[3] CONCURRENT LOCKS"

def concurrent_test(count, threads)
  pool = Concurrent::FixedThreadPool.new(threads)
  done = Concurrent::AtomicFixnum.new(0)
  wins = Concurrent::AtomicFixnum.new(0)

  count.times do
    pool.post do
      item = prepare(create_item(args: random_args))
      ls = SidekiqUniqueJobs::Locksmith.new(item)
      if ls.lock
        wins.increment
        ls.unlock
      end
      done.increment
    rescue StandardError
      done.increment
    end
  end

  sleep 0.1 until done.value >= count
  pool.shutdown
  pool.wait_for_termination(10)
  wins.value
end

Benchmark.ips do |x|
  x.config(time: 10, warmup: 3)
  x.report("100 locks / 10 threads") { concurrent_test(100, 10) }
  x.report("500 locks / 20 threads") { concurrent_test(500, 20) }
end

# === 4: Reaper performance ===
puts "\n[4] REAPER"

# Create 200 locks, half orphaned (no LOCKED hash)
200.times do |i|
  digest = "uniquejobs:bench-reap-#{i}"
  SidekiqUniqueJobs.redis do |conn|
    if i.even?
      # Real lock: has LOCKED hash
      conn.call("HSET", "#{digest}:LOCKED", "jid-#{i}", Time.now.to_f.to_s)
    end
    # All have digests entry
    conn.call("ZADD", "uniquejobs:digests", Time.now.to_f.to_s, digest)
  end
end

Benchmark.ips do |x|
  x.config(time: 10, warmup: 2)

  x.report("reaper cycle") do
    SidekiqUniqueJobs::Server.reap
  end
end

# === 5: Memory ===
puts "\n[5] MEMORY"
Benchmark.memory do |x|
  x.report("100 lock/unlock") do
    100.times do
      item = prepare(create_item(args: random_args))
      ls = SidekiqUniqueJobs::Locksmith.new(item)
      ls.lock
      ls.unlock
    end
  end

  x.report("100 execute") do
    100.times do
      item = prepare(create_item(args: random_args))
      ls = SidekiqUniqueJobs::Locksmith.new(item)
      ls.execute { true }
    end
  end

  x.compare!
end

# === 6: Redis commands per operation ===
puts "\n[6] REDIS KEY COUNT"
SidekiqUniqueJobs.redis { |conn| conn.call("FLUSHDB") }

item = prepare(create_item)
ls = SidekiqUniqueJobs::Locksmith.new(item)
ls.lock

keys = SidekiqUniqueJobs.redis { |conn| conn.call("KEYS", "unique*") }
puts "Keys after lock: #{keys.size} #{keys.inspect}"

ls.unlock

keys_after = SidekiqUniqueJobs.redis { |conn| conn.call("KEYS", "unique*") }
puts "Keys after unlock: #{keys_after.size} #{keys_after.inspect}"

SidekiqUniqueJobs.redis { |conn| conn.call("FLUSHDB") }

puts "\n" + "=" * 70
puts "DONE. Compare results between branches."
puts "=" * 70
