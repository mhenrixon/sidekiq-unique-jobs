#!/usr/bin/env ruby
# frozen_string_literal: true

require "bundler/setup"

# Ensure required gems are available
%w[benchmark/ips benchmark/memory].each do |lib|
  require lib
rescue LoadError
  gem_name = lib.tr("/", "-")
  abort "Missing #{gem_name}. Install: gem install #{gem_name} --no-document"
end

require "sidekiq"
require "sidekiq-unique-jobs"
require "concurrent"

# Configure
Sidekiq.configure_client do |config|
  config.redis = { url: ENV.fetch("REDIS_URL", "redis://localhost:6379/0") }
  config.client_middleware do |chain|
    chain.add SidekiqUniqueJobs::Middleware::Client
  end
end

SidekiqUniqueJobs.configure do |config|
  config.lock_info = false
  config.logger_enabled = false
end

SidekiqUniqueJobs.redis { |conn| conn.call("FLUSHDB") }

puts "=" * 60
puts "sidekiq-unique-jobs v#{SidekiqUniqueJobs::VERSION} Benchmark"
puts "=" * 60
puts "Ruby: #{RUBY_VERSION} | Sidekiq: #{Sidekiq::VERSION}"
puts "Branch: #{`git rev-parse --abbrev-ref HEAD`.chomp}"
puts "Commit: #{`git rev-parse --short HEAD`.chomp}"
puts "=" * 60

def create_item(lock_type: "until_executed", args: %w[arg1 arg2], lock_ttl: nil, lock_limit: 1)
  {
    "jid" => SecureRandom.hex(12),
    "class" => "BenchmarkJob",
    "queue" => "default",
    "lock" => lock_type,
    "args" => args,
    "lock_args" => args,
    "lock_timeout" => 0,
    "lock_ttl" => lock_ttl,
    "lock_limit" => lock_limit,
  }
end

def prepare(item)
  SidekiqUniqueJobs::Job.prepare(item)
  item
end

def random_args
  [SecureRandom.hex(8), { "type" => SecureRandom.hex(4) }]
end

# === Benchmark 1: Lock/Unlock Cycle ===
puts "\n--- Lock/Unlock Cycle ---"

Benchmark.ips do |x|
  x.config(time: 5, warmup: 2)

  x.report("until_executed") do
    item = prepare(create_item(lock_type: "until_executed"))
    ls = SidekiqUniqueJobs::Locksmith.new(item)
    ls.lock
    ls.unlock
  end

  x.report("until_expired (TTL 10s)") do
    item = prepare(create_item(lock_type: "until_expired", lock_ttl: 10_000))
    ls = SidekiqUniqueJobs::Locksmith.new(item)
    ls.lock
    ls.unlock
  end

  x.report("while_executing") do
    item = prepare(create_item(lock_type: "while_executing"))
    ls = SidekiqUniqueJobs::Locksmith.new(item)
    ls.lock
    ls.unlock
  end

  x.compare!
end

# === Benchmark 2: Contention ===
puts "\n--- Lock Contention ---"

Benchmark.ips do |x|
  x.config(time: 5, warmup: 2)

  x.report("no contention (unique args)") do
    item = prepare(create_item(args: random_args))
    ls = SidekiqUniqueJobs::Locksmith.new(item)
    ls.lock
    ls.unlock
  end

  x.report("high contention (same args)") do
    item = prepare(create_item)
    ls1 = SidekiqUniqueJobs::Locksmith.new(item)
    ls1.lock

    item2 = prepare(create_item)
    ls2 = SidekiqUniqueJobs::Locksmith.new(item2)
    ls2.lock # fails (contention)

    ls1.unlock
  end

  x.compare!
end

# === Benchmark 3: Digest Generation ===
puts "\n--- Digest Generation ---"

Benchmark.ips do |x|
  x.config(time: 5, warmup: 2)

  x.report("simple args") do
    SidekiqUniqueJobs::LockDigest.new(create_item(args: %w[simple args])).lock_digest
  end

  x.report("complex args") do
    SidekiqUniqueJobs::LockDigest.new(create_item(args: [
      { "id" => 123, "nested" => { "data" => [1, 2, 3] } },
      %w[array of strings],
    ])).lock_digest
  end

  x.compare!
end

# === Benchmark 4: Concurrent Locking ===
puts "\n--- Concurrent Locking ---"

def concurrent_locks(count, threads)
  pool = Concurrent::FixedThreadPool.new(threads)
  completed = Concurrent::AtomicFixnum.new(0)
  locked = Concurrent::AtomicFixnum.new(0)

  count.times do
    pool.post do
      item = prepare(create_item(args: random_args))
      ls = SidekiqUniqueJobs::Locksmith.new(item)
      if ls.lock
        locked.increment
        ls.unlock
      end
      completed.increment
    rescue StandardError
      completed.increment
    end
  end

  sleep 0.1 until completed.value >= count
  pool.shutdown
  pool.wait_for_termination(10)
  locked.value
end

Benchmark.ips do |x|
  x.config(time: 10, warmup: 2)

  x.report("100 locks / 10 threads") { concurrent_locks(100, 10) }
  x.report("500 locks / 20 threads") { concurrent_locks(500, 20) }
end

# === Benchmark 5: Memory ===
puts "\n--- Memory Usage ---"

Benchmark.memory do |x|
  x.report("lock + unlock") do
    item = prepare(create_item)
    ls = SidekiqUniqueJobs::Locksmith.new(item)
    ls.lock
    ls.unlock
  end

  x.report("lock + execute") do
    item = prepare(create_item)
    ls = SidekiqUniqueJobs::Locksmith.new(item)
    ls.execute { true }
  end

  x.report("100 lock/unlock cycles") do
    100.times do
      item = prepare(create_item(args: random_args))
      ls = SidekiqUniqueJobs::Locksmith.new(item)
      ls.lock
      ls.unlock
    end
  end

  x.compare!
end

# === Benchmark 6: Redis Keys Created ===
puts "\n--- Redis Key Count ---"

SidekiqUniqueJobs.redis { |conn| conn.call("FLUSHDB") }
item = prepare(create_item)
ls = SidekiqUniqueJobs::Locksmith.new(item)
ls.lock

keys = SidekiqUniqueJobs.redis { |conn| conn.call("KEYS", "unique*") }
puts "Keys per lock: #{keys.size}"
keys.each { |k| puts "  #{k}" }

ls.unlock
SidekiqUniqueJobs.redis { |conn| conn.call("FLUSHDB") }

puts "\nBenchmark complete!"
